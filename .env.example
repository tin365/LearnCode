# Environment: development | production | test
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/learncode"

# Auth
# In production, JWT_SECRET and COOKIE_SECRET must both be strong random
# strings (>= 32 chars) and must NOT match the example values above. Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Use distinct values for JWT_SECRET and COOKIE_SECRET so leaking one
# doesn't compromise the other.
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"
COOKIE_SECRET="change-this-to-a-different-random-string-in-production"

# API
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated list of browser origins allowed by CORS. Tauri origins
# (tauri://localhost, https://tauri.localhost) are always allowed.
WEB_ORIGINS=http://localhost:5173

# Web
VITE_API_URL=http://localhost:3001

# Observability (Sentry) — optional. When SENTRY_DSN / VITE_SENTRY_DSN
# are unset, Sentry no-ops (no errors are sent). Get a DSN at
# https://sentry.io. Use different projects for web and API.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=

# OAuth providers — optional. If a provider's CLIENT_ID/SECRET pair is
# unset, its routes are not registered (the "Continue with X" button on
# the frontend will 404 against the API).
#
# API_BASE_URL is the public URL of THIS API, used to construct OAuth
# redirect URIs. It MUST exactly match what you register with each
# provider (Google Cloud Console > Credentials > Authorized redirect URIs).
#   Local dev:  API_BASE_URL=http://localhost:3001
#   Production: API_BASE_URL=https://api.learncode.study
#
# Google: create an OAuth 2.0 Client ID at
# https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: {API_BASE_URL}/auth/google/callback
#
# Facebook: create an app at https://developers.facebook.com/apps, add
# the "Facebook Login" product, set the redirect URI in Facebook Login >
# Settings > Valid OAuth Redirect URIs:
#   {API_BASE_URL}/auth/facebook/callback
# Until the app is submitted for App Review, only people listed as Admin,
# Developer, or Tester on the FB app can complete sign-in.
API_BASE_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Transactional email (Resend) — required for password reset in production.
# If unset, password-reset emails are logged to the API console instead of
# sent, so the full flow can be exercised in dev without signing up.
#
# To enable for real:
#   1. Sign up at https://resend.com (free tier: 100 emails/day)
#   2. Add learncode.study as a sending domain, add the DNS records they
#      provide to Cloudflare DNS, wait for verification
#   3. Create an API key (Resend dashboard > API keys)
#   4. EMAIL_FROM must be on the verified domain
RESEND_API_KEY=
EMAIL_FROM=noreply@learncode.study
