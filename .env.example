# Environment: development | production | test
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/learncode"

# Auth
# In production, JWT_SECRET and COOKIE_SECRET must both be strong random
# strings (>= 32 chars) and must NOT match the example values above. Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Use distinct values for JWT_SECRET and COOKIE_SECRET so leaking one
# doesn't compromise the other.
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"
COOKIE_SECRET="change-this-to-a-different-random-string-in-production"

# API
API_PORT=3001
API_HOST=0.0.0.0
# Comma-separated list of browser origins allowed by CORS. Tauri origins
# (tauri://localhost, https://tauri.localhost) are always allowed.
WEB_ORIGINS=http://localhost:5173

# Web
VITE_API_URL=http://localhost:3001

# Observability (Sentry) — optional. When SENTRY_DSN / VITE_SENTRY_DSN
# are unset, Sentry no-ops (no errors are sent). Get a DSN at
# https://sentry.io. Use different projects for web and API.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
